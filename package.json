    "git",
    "developer-tools",
    "dotghost"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NicholasCullenCooper/dotghost.git"
  },
  "homepage": "https://github.com/NicholasCullenCooper/dotghost#readme",
