{
  "name": "dotghost",
  "version": "1.2.0",
  "description": "Keep AGENTS.md, agents, commands, workflows, and skills in sync across repos.",
  "type": "module",
  "bin": {
    "dotghost": "dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
